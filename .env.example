# 本地开发环境变量示例
# 复制为 .env.local 后使用

# 本地 MySQL（见 docs/database/mysql-setup.md）
DATABASE_URL="mysql://creator:creator_dev_pass@127.0.0.1:3306/artist_assets"

# 本地图片存储（见 docs/storage/local-storage.md）
STORAGE_TYPE=local
STORAGE_ROOT=D:\开发\艺术家个人资产体系\storage\uploads
STORAGE_PUBLIC_BASE=http://localhost:3000/api/media
STORAGE_MAX_FILE_MB=10

# AI
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 认证
JWT_SECRET=change-me-to-a-long-random-string

# 开发期跳过短信登录
MOCK_AUTH=true
